  "repository": {
    "type": "git",
    "url": "git+https://github.com/markarranz/opencode-focus-notify.git"
  },
  "homepage": "https://github.com/markarranz/opencode-focus-notify#readme",
  "bugs": {
    "url": "https://github.com/markarranz/opencode-focus-notify/issues"
